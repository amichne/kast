{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amichne/kast/evaluation/benchmark.schema.json",
  "title": "Kast system evaluation benchmark",
  "description": "Authoritative benchmark artifact. Version 2 separates mechanical, LLM-graded, and combined summary surfaces; version 1 remains accepted for historical benchmark artifacts.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/benchmarkV2" },
    { "$ref": "#/$defs/benchmarkV1" }
  ],
  "$defs": {
    "benchmarkV2": {
      "type": "object",
      "required": [
        "$schema",
        "schema_version",
        "benchmark_kind",
        "metadata",
        "runs",
        "mechanical_summary",
        "llm_graded_summary",
        "combined_summary",
        "summary",
        "paired_analysis"
      ],
      "additionalProperties": false,
      "properties": {
        "$schema": { "type": "string", "const": "https://github.com/amichne/kast/evaluation/benchmark.schema.json" },
        "schema_version": { "type": "integer", "const": 2 },
        "benchmark_kind": { "type": "string", "const": "kast-system-performance-benchmark" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "runs": {
          "type": "array",
          "items": { "$ref": "#/$defs/runV2" }
        },
        "mechanical_summary": { "$ref": "#/$defs/summarySurface" },
        "llm_graded_summary": { "$ref": "#/$defs/summarySurface" },
        "combined_summary": { "$ref": "#/$defs/summarySurface" },
        "summary": { "$ref": "#/$defs/summarySurface" },
        "paired_analysis": { "$ref": "#/$defs/pairedAnalysis" }
      }
    },
    "benchmarkV1": {
      "type": "object",
      "required": [
        "$schema",
        "schema_version",
        "benchmark_kind",
        "metadata",
        "runs",
        "summary",
        "paired_analysis"
      ],
      "additionalProperties": false,
      "properties": {
        "$schema": { "type": "string", "const": "https://github.com/amichne/kast/evaluation/benchmark.schema.json" },
        "schema_version": { "type": "integer", "const": 1 },
        "benchmark_kind": { "type": "string", "const": "kast-system-performance-benchmark" },
        "metadata": { "$ref": "#/$defs/metadata" },
        "runs": {
          "type": "array",
          "items": { "$ref": "#/$defs/runV1" }
        },
        "summary": { "$ref": "#/$defs/summarySurface" },
        "paired_analysis": { "$ref": "#/$defs/pairedAnalysis" }
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "skill_name",
        "skill_path",
        "generated_at",
        "iteration_dir",
        "target_repo",
        "workspace_root",
        "eval_ids",
        "configurations",
        "runs_per_eval_per_config",
        "catalog_version",
        "primary_dimensions",
        "supporting_metrics",
        "execution_environment"
      ],
      "additionalProperties": false,
      "properties": {
        "skill_name": { "$ref": "#/$defs/nonEmptyString" },
        "skill_path": { "$ref": "#/$defs/nonEmptyString" },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "iteration_dir": { "$ref": "#/$defs/nonEmptyString" },
        "target_repo": { "$ref": "#/$defs/nonEmptyString" },
        "workspace_root": { "$ref": "#/$defs/nonEmptyString" },
        "target_git_sha": { "$ref": "#/$defs/nonEmptyString" },
        "eval_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/evalId" }
        },
        "configurations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/configuration" }
        },
        "runs_per_eval_per_config": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/configurationRunCounts" }
        },
        "catalog_version": { "type": "integer", "minimum": 1 },
        "primary_dimensions": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/primaryDimension" }
        },
        "supporting_metrics": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "efficiency",
              "transcript_chars",
              "total_tool_calls",
              "semantic_tool_calls",
              "generic_search_calls",
              "executor_duration_seconds",
              "input_tokens",
              "output_tokens",
              "cache_read_tokens",
              "total_tokens",
              "errors_encountered"
            ]
          }
        },
        "execution_environment": {
          "type": "object",
          "required": ["platform", "python_version", "cpu_count"],
          "additionalProperties": false,
          "properties": {
            "platform": { "$ref": "#/$defs/nonEmptyString" },
            "python_version": { "$ref": "#/$defs/nonEmptyString" },
            "cpu_count": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "runV2": {
      "type": "object",
      "required": [
        "eval_id",
        "configuration",
        "run_number",
        "mechanical",
        "llm_graded",
        "combined",
        "expectations",
        "efficiency",
        "integrity",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "eval_id": { "$ref": "#/$defs/evalId" },
        "configuration": { "$ref": "#/$defs/configuration" },
        "run_number": { "type": "integer", "minimum": 1 },
        "mechanical": { "$ref": "#/$defs/runSurface" },
        "llm_graded": { "$ref": "#/$defs/runSurface" },
        "combined": { "$ref": "#/$defs/runSurface" },
        "expectations": {
          "type": "array",
          "items": { "$ref": "#/$defs/expectation" }
        },
        "efficiency": { "$ref": "#/$defs/runEfficiency" },
        "integrity": { "$ref": "#/$defs/integrity" },
        "status": { "type": "string", "enum": ["valid", "invalid"] },
        "measurements": { "$ref": "#/$defs/runMeasurements" },
        "invalid_reason": {
          "type": "string",
          "enum": [
            "ungraded_expectation",
            "baseline_tainted",
            "contradictory_grading",
            "mock_backend_error",
            "executor_failed",
            "empty_transcript",
            "hook_error"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "valid" } },
            "required": ["status"]
          },
          "then": { "required": ["measurements"] }
        },
        {
          "if": {
            "properties": { "status": { "const": "invalid" } },
            "required": ["status"]
          },
          "then": { "required": ["invalid_reason"] }
        }
      ]
    },
    "runV1": {
      "type": "object",
      "required": [
        "eval_id",
        "configuration",
        "run_number",
        "expectations",
        "efficiency",
        "integrity",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "eval_id": { "$ref": "#/$defs/evalId" },
        "configuration": { "$ref": "#/$defs/configuration" },
        "run_number": { "type": "integer", "minimum": 1 },
        "expectations": {
          "type": "array",
          "items": { "$ref": "#/$defs/expectation" }
        },
        "efficiency": { "$ref": "#/$defs/runEfficiency" },
        "integrity": { "$ref": "#/$defs/integrity" },
        "status": { "type": "string", "enum": ["valid", "invalid"] },
        "measurements": { "$ref": "#/$defs/runMeasurements" },
        "invalid_reason": {
          "type": "string",
          "enum": [
            "ungraded_expectation",
            "baseline_tainted",
            "contradictory_grading",
            "mock_backend_error",
            "executor_failed",
            "empty_transcript",
            "hook_error"
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "const": "valid" } },
            "required": ["status"]
          },
          "then": { "required": ["measurements"] }
        },
        {
          "if": {
            "properties": { "status": { "const": "invalid" } },
            "required": ["status"]
          },
          "then": { "required": ["invalid_reason"] }
        }
      ]
    },
    "runSurface": {
      "type": "object",
      "required": ["status", "expectations", "summary", "measurements"],
      "additionalProperties": false,
      "properties": {
        "status": { "$ref": "#/$defs/nonEmptyString" },
        "expectations": {
          "type": "array",
          "items": { "$ref": "#/$defs/expectation" }
        },
        "summary": { "$ref": "#/$defs/gradingSummary" },
        "measurements": { "$ref": "#/$defs/runMeasurements" },
        "execution_metrics": { "$ref": "#/$defs/executionMetrics" },
        "timing": { "$ref": "#/$defs/timing" },
        "artifacts": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/nonEmptyString" }
        },
        "identity": {
          "type": "object",
          "additionalProperties": true
        },
        "tokens": {
          "type": "object",
          "additionalProperties": true
        },
        "tool_metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "permission_metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "build_test_iterations": {
          "type": "object",
          "additionalProperties": true
        },
        "repo_state": {
          "type": "object",
          "additionalProperties": true
        },
        "harness_validation": {
          "type": "object",
          "additionalProperties": true
        },
        "rubric_results": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        }
      }
    },
    "summarySurface": {
      "type": "object",
      "required": ["by_configuration"],
      "additionalProperties": false,
      "properties": {
        "by_configuration": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": false,
          "properties": {
            "with_skill": { "$ref": "#/$defs/configurationSummary" },
            "tool_only": { "$ref": "#/$defs/configurationSummary" },
            "without_skill": { "$ref": "#/$defs/configurationSummary" }
          }
        }
      }
    },
    "configurationSummary": {
      "type": "object",
      "required": ["run_counts", "measurements", "efficiency"],
      "additionalProperties": false,
      "properties": {
        "run_counts": {
          "type": "object",
          "required": ["total", "valid", "invalid"],
          "additionalProperties": false,
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "valid": { "type": "integer", "minimum": 0 },
            "invalid": { "type": "integer", "minimum": 0 }
          }
        },
        "measurements": { "$ref": "#/$defs/summaryMeasurements" },
        "efficiency": { "$ref": "#/$defs/summaryEfficiency" }
      }
    },
    "summaryMeasurements": {
      "type": "object",
      "required": ["overall", "task_completion", "accuracy", "reliability", "scope_control", "efficiency"],
      "additionalProperties": false,
      "properties": {
        "overall": { "$ref": "#/$defs/summaryMeasurementCard" },
        "task_completion": { "$ref": "#/$defs/summaryMeasurementCard" },
        "accuracy": { "$ref": "#/$defs/summaryMeasurementCard" },
        "reliability": { "$ref": "#/$defs/summaryMeasurementCard" },
        "scope_control": { "$ref": "#/$defs/summaryMeasurementCard" },
        "efficiency": { "$ref": "#/$defs/summaryMeasurementCard" }
      }
    },
    "summaryMeasurementCard": {
      "type": "object",
      "required": ["all", "outcome", "process"],
      "additionalProperties": false,
      "properties": {
        "all": { "$ref": "#/$defs/distribution" },
        "outcome": { "$ref": "#/$defs/distribution" },
        "process": { "$ref": "#/$defs/distribution" }
      }
    },
    "runMeasurements": {
      "type": "object",
      "required": ["overall", "task_completion", "accuracy", "reliability", "scope_control", "efficiency"],
      "additionalProperties": false,
      "properties": {
        "overall": { "$ref": "#/$defs/runMeasurementCard" },
        "task_completion": { "$ref": "#/$defs/runMeasurementCard" },
        "accuracy": { "$ref": "#/$defs/runMeasurementCard" },
        "reliability": { "$ref": "#/$defs/runMeasurementCard" },
        "scope_control": { "$ref": "#/$defs/runMeasurementCard" },
        "efficiency": { "$ref": "#/$defs/runMeasurementCard" }
      }
    },
    "runMeasurementCard": {
      "type": "object",
      "required": ["all", "outcome", "process"],
      "additionalProperties": false,
      "properties": {
        "all": { "$ref": "#/$defs/scoreGroup" },
        "outcome": { "$ref": "#/$defs/scoreGroup" },
        "process": { "$ref": "#/$defs/scoreGroup" }
      }
    },
    "scoreGroup": {
      "oneOf": [
        {
          "type": "object",
          "required": ["status", "eligible", "passed", "failed", "not_applicable", "score"],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "const": "scored" },
            "eligible": { "type": "integer", "minimum": 1 },
            "passed": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "not_applicable": { "type": "integer", "minimum": 0 },
            "score": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        },
        {
          "type": "object",
          "required": ["status", "eligible", "not_applicable"],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "const": "not_applicable" },
            "eligible": { "type": "integer", "const": 0 },
            "not_applicable": { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },
    "distribution": {
      "oneOf": [
        {
          "type": "object",
          "required": ["status", "n"],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "const": "no_valid_samples" },
            "n": { "type": "integer", "const": 0 }
          }
        },
        {
          "type": "object",
          "required": ["status", "n", "mean", "stddev", "min", "max", "confidence_interval_95"],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "const": "summarized" },
            "n": { "type": "integer", "minimum": 1 },
            "mean": { "type": "number" },
            "stddev": { "type": "number", "minimum": 0.0 },
            "min": { "type": "number" },
            "max": { "type": "number" },
            "confidence_interval_95": {
              "type": "object",
              "required": ["level", "lower", "upper", "method"],
              "additionalProperties": false,
              "properties": {
                "level": { "type": "number", "const": 0.95 },
                "lower": { "type": "number" },
                "upper": { "type": "number" },
                "method": {
                  "type": "string",
                  "enum": ["normal_approximation", "degenerate_single_sample"]
                }
              }
            }
          }
        }
      ]
    },
    "summaryEfficiency": {
      "type": "object",
      "required": [
        "transcript_chars",
        "total_tool_calls",
        "semantic_tool_calls",
        "generic_search_calls",
        "executor_duration_seconds",
        "input_tokens",
        "output_tokens",
        "cache_read_tokens",
        "total_tokens",
        "errors_encountered"
      ],
      "additionalProperties": false,
      "properties": {
        "transcript_chars": { "$ref": "#/$defs/distribution" },
        "total_tool_calls": { "$ref": "#/$defs/distribution" },
        "semantic_tool_calls": { "$ref": "#/$defs/distribution" },
        "generic_search_calls": { "$ref": "#/$defs/distribution" },
        "executor_duration_seconds": { "$ref": "#/$defs/distribution" },
        "input_tokens": { "$ref": "#/$defs/distribution" },
        "output_tokens": { "$ref": "#/$defs/distribution" },
        "cache_read_tokens": { "$ref": "#/$defs/distribution" },
        "total_tokens": { "$ref": "#/$defs/distribution" },
        "errors_encountered": { "$ref": "#/$defs/distribution" }
      }
    },
    "runEfficiency": {
      "type": "object",
      "required": [
        "transcript_chars",
        "total_tool_calls",
        "semantic_tool_calls",
        "generic_search_calls",
        "executor_duration_seconds",
        "executor_duration_source",
        "input_tokens",
        "output_tokens",
        "cache_read_tokens",
        "total_tokens",
        "errors_encountered"
      ],
      "additionalProperties": false,
      "properties": {
        "transcript_chars": { "type": "integer", "minimum": 0 },
        "total_tool_calls": { "type": "integer", "minimum": 0 },
        "semantic_tool_calls": { "type": "integer", "minimum": 0 },
        "generic_search_calls": { "type": "integer", "minimum": 0 },
        "executor_duration_seconds": { "type": "number", "minimum": 0.0 },
        "executor_duration_source": { "$ref": "#/$defs/nonEmptyString" },
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "cache_read_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 },
        "errors_encountered": { "type": "integer", "minimum": 0 }
      }
    },
    "expectation": {
      "type": "object",
      "required": ["id", "text", "kind", "dimension", "applicability", "graded_by", "status"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/nonEmptyString" },
        "text": { "$ref": "#/$defs/nonEmptyString" },
        "kind": { "type": "string", "enum": ["outcome", "process"] },
        "dimension": { "$ref": "#/$defs/dimension" },
        "applicability": {
          "type": "string",
          "enum": ["both", "with_skill_only", "without_skill_only"]
        },
        "graded_by": { "type": "string", "enum": ["script", "llm", "n/a"] },
        "oracle": { "$ref": "#/$defs/nonEmptyString" },
        "status": {
          "type": "string",
          "enum": ["passed", "failed", "not_applicable", "ungraded"]
        },
        "evidence": { "$ref": "#/$defs/evidence" },
        "reason": { "$ref": "#/$defs/nonEmptyString" },
        "error": { "$ref": "#/$defs/nonEmptyString" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "status": { "enum": ["passed", "failed"] } },
            "required": ["status"]
          },
          "then": { "required": ["evidence"] }
        }
      ]
    },
    "evidence": {
      "type": "object",
      "required": ["kind", "summary"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["automated_check", "llm_judgment"]
        },
        "summary": { "$ref": "#/$defs/nonEmptyString" },
        "citations": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        }
      }
    },
    "gradingSummary": {
      "type": "object",
      "required": [
        "passed",
        "failed",
        "total",
        "pass_rate",
        "outcome_passed",
        "outcome_total",
        "outcome_pass_rate",
        "process_pass_rate",
        "skipped"
      ],
      "additionalProperties": true,
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "pass_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "outcome_passed": { "type": "integer", "minimum": 0 },
        "outcome_total": { "type": "integer", "minimum": 0 },
        "outcome_pass_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "process_pass_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "skipped": { "type": "integer", "minimum": 0 }
      }
    },
    "executionMetrics": {
      "type": "object",
      "required": [
        "tool_calls",
        "total_tool_calls",
        "total_steps",
        "errors_encountered",
        "output_chars",
        "transcript_chars"
      ],
      "additionalProperties": true,
      "properties": {
        "tool_calls": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "tool_call_log": { "$ref": "#/$defs/nonEmptyString" },
        "total_tool_calls": { "type": "integer", "minimum": 0 },
        "total_steps": { "type": "integer", "minimum": 0 },
        "errors_encountered": { "type": "integer", "minimum": 0 },
        "output_chars": { "type": "integer", "minimum": 0 },
        "transcript_chars": { "type": "integer", "minimum": 0 },
        "kast_calls": { "type": "integer", "minimum": 0 },
        "grep_or_find_calls": { "type": "integer", "minimum": 0 }
      }
    },
    "timing": {
      "type": "object",
      "required": ["executor_duration_seconds", "grader_duration_seconds", "total_duration_seconds"],
      "additionalProperties": true,
      "properties": {
        "executor_duration_seconds": { "type": "number", "minimum": 0.0 },
        "grader_duration_seconds": { "type": "number", "minimum": 0.0 },
        "total_duration_seconds": { "type": "number", "minimum": 0.0 },
        "executor_duration_source": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "integrity": {
      "type": "object",
      "required": [
        "attempts",
        "flaky",
        "baseline_isolation",
        "contradiction_count",
        "contradiction_samples",
        "executor_status",
        "executor_exit_code",
        "executor_message",
        "transcript_present",
        "hook_error_count",
        "hook_error_samples",
        "session_error_count",
        "session_error_samples",
        "workspace_dirty_post"
      ],
      "additionalProperties": false,
      "properties": {
        "attempts": { "type": "integer", "minimum": 1 },
        "flaky": { "type": "boolean" },
        "baseline_isolation": {
          "type": "string",
          "enum": ["intact", "violated", "not_applicable"]
        },
        "contradiction_count": { "type": "integer", "minimum": 0 },
        "contradiction_samples": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "executor_status": { "type": "string" },
        "executor_exit_code": { "type": ["integer", "null"] },
        "executor_message": { "type": "string" },
        "transcript_present": { "type": "boolean" },
        "hook_error_count": { "type": "integer", "minimum": 0 },
        "hook_error_samples": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "session_error_count": { "type": "integer", "minimum": 0 },
        "session_error_samples": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "mock_backend_error_count": { "type": "integer", "minimum": 0 },
        "mock_backend_error_samples": {
          "type": "array",
          "items": { "$ref": "#/$defs/nonEmptyString" }
        },
        "workspace_dirty_post": { "type": "boolean" },
        "git_sha_post": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "pairedAnalysis": {
      "type": "object",
      "required": ["pair_unit", "pairs", "statistics", "issues"],
      "additionalProperties": false,
      "properties": {
        "pair_unit": { "type": "string", "const": "eval_id" },
        "pairs": {
          "type": "array",
          "items": { "$ref": "#/$defs/pairRecord" }
        },
        "statistics": {
          "type": "object",
          "required": ["score_metrics", "efficiency_metrics"],
          "additionalProperties": false,
          "properties": {
            "score_metrics": {
              "type": "object",
              "required": ["overall_outcome", "task_completion", "accuracy", "reliability", "scope_control"],
              "additionalProperties": false,
              "properties": {
                "overall_outcome": { "$ref": "#/$defs/statisticalTest" },
                "task_completion": { "$ref": "#/$defs/statisticalTest" },
                "accuracy": { "$ref": "#/$defs/statisticalTest" },
                "reliability": { "$ref": "#/$defs/statisticalTest" },
                "scope_control": { "$ref": "#/$defs/statisticalTest" }
              }
            },
            "efficiency_metrics": {
              "type": "object",
              "required": [
                "transcript_chars",
                "total_tool_calls",
                "semantic_tool_calls",
                "generic_search_calls",
                "executor_duration_seconds",
                "input_tokens",
                "output_tokens",
                "cache_read_tokens",
                "total_tokens"
              ],
              "additionalProperties": false,
              "properties": {
                "transcript_chars": { "$ref": "#/$defs/statisticalTest" },
                "total_tool_calls": { "$ref": "#/$defs/statisticalTest" },
                "semantic_tool_calls": { "$ref": "#/$defs/statisticalTest" },
                "generic_search_calls": { "$ref": "#/$defs/statisticalTest" },
                "executor_duration_seconds": { "$ref": "#/$defs/statisticalTest" },
                "input_tokens": { "$ref": "#/$defs/statisticalTest" },
                "output_tokens": { "$ref": "#/$defs/statisticalTest" },
                "cache_read_tokens": { "$ref": "#/$defs/statisticalTest" },
                "total_tokens": { "$ref": "#/$defs/statisticalTest" }
              }
            }
          }
        },
        "issues": {
          "type": "object",
          "required": ["invalid_runs", "flaky_runs", "outliers"],
          "additionalProperties": false,
          "properties": {
            "invalid_runs": {
              "type": "array",
              "items": { "$ref": "#/$defs/invalidRunIssue" }
            },
            "flaky_runs": {
              "type": "array",
              "items": { "$ref": "#/$defs/flakyRunIssue" }
            },
            "outliers": {
              "type": "array",
              "items": { "$ref": "#/$defs/outlierIssue" }
            }
          }
        }
      }
    },
    "pairRecord": {
      "type": "object",
      "required": [
        "eval_id",
        "with_skill_run_numbers",
        "without_skill_run_numbers",
        "score_deltas",
        "efficiency_deltas"
      ],
      "additionalProperties": false,
      "properties": {
        "eval_id": { "$ref": "#/$defs/evalId" },
        "with_skill_run_numbers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 1 }
        },
        "without_skill_run_numbers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "integer", "minimum": 1 }
        },
        "score_deltas": {
          "type": "object",
          "required": ["overall_outcome", "task_completion", "accuracy", "reliability", "scope_control"],
          "additionalProperties": false,
          "properties": {
            "overall_outcome": { "$ref": "#/$defs/scoreDelta" },
            "task_completion": { "$ref": "#/$defs/scoreDelta" },
            "accuracy": { "$ref": "#/$defs/scoreDelta" },
            "reliability": { "$ref": "#/$defs/scoreDelta" },
            "scope_control": { "$ref": "#/$defs/scoreDelta" }
          }
        },
        "efficiency_deltas": {
          "type": "object",
          "required": [
            "transcript_chars",
            "total_tool_calls",
            "semantic_tool_calls",
            "generic_search_calls",
            "executor_duration_seconds",
            "input_tokens",
            "output_tokens",
            "cache_read_tokens",
            "total_tokens"
          ],
          "additionalProperties": false,
          "properties": {
            "transcript_chars": { "$ref": "#/$defs/numericDelta" },
            "total_tool_calls": { "$ref": "#/$defs/numericDelta" },
            "semantic_tool_calls": { "$ref": "#/$defs/numericDelta" },
            "generic_search_calls": { "$ref": "#/$defs/numericDelta" },
            "executor_duration_seconds": { "$ref": "#/$defs/numericDelta" },
            "input_tokens": { "$ref": "#/$defs/numericDelta" },
            "output_tokens": { "$ref": "#/$defs/numericDelta" },
            "cache_read_tokens": { "$ref": "#/$defs/numericDelta" },
            "total_tokens": { "$ref": "#/$defs/numericDelta" }
          }
        }
      }
    },
    "scoreDelta": {
      "oneOf": [
        {
          "type": "object",
          "required": ["status"],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "const": "not_applicable" }
          }
        },
        {
          "type": "object",
          "required": ["status", "with_skill_mean", "without_skill_mean", "delta"],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "const": "scored" },
            "with_skill_mean": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "without_skill_mean": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "delta": { "type": "number", "minimum": -1.0, "maximum": 1.0 }
          }
        }
      ]
    },
    "numericDelta": {
      "type": "object",
      "required": ["with_skill_mean", "without_skill_mean", "delta"],
      "additionalProperties": false,
      "properties": {
        "with_skill_mean": { "type": "number" },
        "without_skill_mean": { "type": "number" },
        "delta": { "type": "number" }
      }
    },
    "statisticalTest": {
      "oneOf": [
        {
          "type": "object",
          "required": ["status", "n_pairs"],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "const": "not_applicable" },
            "n_pairs": { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "required": [
            "status",
            "test_name",
            "alternative",
            "zero_method",
            "correction",
            "statistic",
            "p_value",
            "n_pairs",
            "method",
            "effect_size_rank_biserial",
            "mean_delta",
            "median_delta"
          ],
          "additionalProperties": false,
          "properties": {
            "status": { "type": "string", "const": "scored" },
            "test_name": { "type": "string", "const": "wilcoxon_signed_rank" },
            "alternative": { "type": "string", "const": "two_sided" },
            "zero_method": { "type": "string", "const": "wilcox" },
            "correction": { "type": "string", "enum": ["none"] },
            "statistic": { "type": "number", "minimum": 0.0 },
            "p_value": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "n_pairs": { "type": "integer", "minimum": 1 },
            "method": { "type": "string", "enum": ["exact", "normal_approx", "no_variance"] },
            "effect_size_rank_biserial": { "type": "number", "minimum": -1.0, "maximum": 1.0 },
            "mean_delta": { "type": "number" },
            "median_delta": { "type": "number" }
          }
        }
      ]
    },
    "invalidRunIssue": {
      "type": "object",
      "required": ["eval_id", "configuration", "run_number", "reason"],
      "additionalProperties": false,
      "properties": {
        "eval_id": { "$ref": "#/$defs/evalId" },
        "configuration": { "$ref": "#/$defs/configuration" },
        "run_number": { "type": "integer", "minimum": 1 },
        "reason": { "$ref": "#/$defs/nonEmptyString" }
      }
    },
    "flakyRunIssue": {
      "type": "object",
      "required": ["eval_id", "configuration", "run_number", "attempts"],
      "additionalProperties": false,
      "properties": {
        "eval_id": { "$ref": "#/$defs/evalId" },
        "configuration": { "$ref": "#/$defs/configuration" },
        "run_number": { "type": "integer", "minimum": 1 },
        "attempts": { "type": "integer", "minimum": 2 }
      }
    },
    "outlierIssue": {
      "type": "object",
      "required": ["configuration", "metric", "eval_id", "value", "side"],
      "additionalProperties": false,
      "properties": {
        "configuration": { "$ref": "#/$defs/configuration" },
        "metric": {
          "type": "string",
          "enum": ["overall_outcome_score", "transcript_chars", "executor_duration_seconds"]
        },
        "eval_id": { "$ref": "#/$defs/evalId" },
        "value": { "type": "number" },
        "side": { "type": "string", "enum": ["low", "high"] }
      }
    },
    "configurationRunCounts": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,
      "properties": {
        "with_skill": { "type": "integer", "minimum": 0 },
        "tool_only": { "type": "integer", "minimum": 0 },
        "without_skill": { "type": "integer", "minimum": 0 }
      }
    },
    "configuration": {
      "type": "string",
      "enum": ["with_skill", "tool_only", "without_skill"]
    },
    "primaryDimension": {
      "type": "string",
      "enum": ["task_completion", "accuracy", "reliability", "scope_control"]
    },
    "dimension": {
      "type": "string",
      "enum": ["task_completion", "accuracy", "reliability", "scope_control", "efficiency"]
    },
    "evalId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    }
  }
}
