{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amichne/kast/evaluation/bindings.schema.json",
  "title": "Kast evaluation codebase bindings",
  "description": "Maps abstract eval slots to concrete symbols in a target Kotlin codebase, plus optional ground-truth oracles used for outcome grading.",
  "type": "object",
  "required": ["target_repo", "workspace_root", "slots"],
  "additionalProperties": false,
  "properties": {
    "_comment": { "type": "string" },
    "target_repo": {
      "type": "string",
      "minLength": 1,
      "description": "Target Kotlin repository name or path label."
    },
    "workspace_root": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute path to the target repository checkout."
    },
    "git_sha": {
      "type": "string",
      "description": "Optional git SHA recorded at run time for reproducibility. The runner SHOULD overwrite this before each iteration."
    },
    "slots": {
      "type": "object",
      "required": [
        "SEALED_HIERARCHY",
        "DISAMBIGUATE_MEMBER",
        "CROSS_MODULE_CLASS",
        "OVERLOADED_OR_COMMON_FUNCTION",
        "RENAME_TARGET",
        "LARGE_CLASS",
        "MODULE_LIST"
      ],
      "additionalProperties": false,
      "properties": {
        "SEALED_HIERARCHY": { "$ref": "#/$defs/sealed_slot" },
        "DISAMBIGUATE_MEMBER": { "$ref": "#/$defs/member_slot" },
        "CROSS_MODULE_CLASS": { "$ref": "#/$defs/cross_module_slot" },
        "OVERLOADED_OR_COMMON_FUNCTION": { "$ref": "#/$defs/function_slot" },
        "RENAME_TARGET": { "$ref": "#/$defs/rename_slot" },
        "LARGE_CLASS": { "$ref": "#/$defs/large_class_slot" },
        "MODULE_LIST": { "$ref": "#/$defs/module_list_slot" }
      }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "symbol_ref": {
      "type": "object",
      "required": ["symbol", "fqName", "file", "description"],
      "additionalProperties": false,
      "properties": {
        "_comment": { "type": "string" },
        "symbol": { "$ref": "#/$defs/non_empty_string" },
        "fqName": { "$ref": "#/$defs/non_empty_string" },
        "file": { "$ref": "#/$defs/non_empty_string" },
        "description": { "$ref": "#/$defs/non_empty_string" }
      }
    },
    "sealed_slot": {
      "type": "object",
      "required": ["symbol", "fqName", "file", "description"],
      "additionalProperties": false,
      "properties": {
        "_comment": { "type": "string" },
        "symbol": { "$ref": "#/$defs/non_empty_string" },
        "fqName": { "$ref": "#/$defs/non_empty_string" },
        "file": { "$ref": "#/$defs/non_empty_string" },
        "description": { "$ref": "#/$defs/non_empty_string" },
        "expected": {
          "type": "object",
          "description": "Ground truth for sealed-hierarchy traceability. Implementation list is a closed set under the workspace; populate completely.",
          "required": ["implementations"],
          "additionalProperties": false,
          "properties": {
            "_comment": { "type": "string" },
            "implementations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["fqName", "module"],
                "additionalProperties": false,
                "properties": {
                  "fqName": { "$ref": "#/$defs/non_empty_string" },
                  "module": { "$ref": "#/$defs/non_empty_string" },
                  "file": { "type": "string" }
                }
              }
            },
            "modules": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" },
              "description": "Modules expected to host at least one implementation."
            }
          }
        }
      }
    },
    "member_slot": {
      "type": "object",
      "required": ["symbol", "fqName", "file", "description", "containingType"],
      "additionalProperties": false,
      "properties": {
        "_comment": { "type": "string" },
        "symbol": { "$ref": "#/$defs/non_empty_string" },
        "fqName": { "$ref": "#/$defs/non_empty_string" },
        "file": { "$ref": "#/$defs/non_empty_string" },
        "description": { "$ref": "#/$defs/non_empty_string" },
        "containingType": { "$ref": "#/$defs/non_empty_string" },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "_comment": { "type": "string" },
            "minimumUsageSites": { "type": "integer", "minimum": 1 },
            "expectedFiles": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" },
              "description": "Files expected to contain a real usage. Set is a non-strict subset (recall floor)."
            },
            "decoyFiles": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" },
              "description": "Files containing the same identifier on unrelated types; a precision trap a text-only run will hit."
            }
          }
        }
      }
    },
    "function_slot": {
      "type": "object",
      "required": ["symbol", "fqName", "file", "description", "containingType"],
      "additionalProperties": false,
      "properties": {
        "_comment": { "type": "string" },
        "symbol": { "$ref": "#/$defs/non_empty_string" },
        "fqName": { "$ref": "#/$defs/non_empty_string" },
        "file": { "$ref": "#/$defs/non_empty_string" },
        "description": { "$ref": "#/$defs/non_empty_string" },
        "containingType": { "$ref": "#/$defs/non_empty_string" },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "_comment": { "type": "string" },
            "minimumCallers": { "type": "integer", "minimum": 1 },
            "expectedCallerFqNames": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" }
            },
            "expectedCallerModules": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" }
            }
          }
        }
      }
    },
    "cross_module_slot": {
      "type": "object",
      "required": ["symbol", "fqName", "file", "description"],
      "additionalProperties": false,
      "properties": {
        "_comment": { "type": "string" },
        "symbol": { "$ref": "#/$defs/non_empty_string" },
        "fqName": { "$ref": "#/$defs/non_empty_string" },
        "file": { "$ref": "#/$defs/non_empty_string" },
        "description": { "$ref": "#/$defs/non_empty_string" },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "_comment": { "type": "string" },
            "minimumReferences": { "type": "integer", "minimum": 1 },
            "expectedConsumerModules": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/non_empty_string" }
            },
            "expectedConsumerFiles": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" }
            }
          }
        }
      }
    },
    "rename_slot": {
      "type": "object",
      "required": ["symbol", "fqName", "file", "description", "newName"],
      "additionalProperties": false,
      "properties": {
        "_comment": { "type": "string" },
        "symbol": { "$ref": "#/$defs/non_empty_string" },
        "fqName": { "$ref": "#/$defs/non_empty_string" },
        "file": { "$ref": "#/$defs/non_empty_string" },
        "description": { "$ref": "#/$defs/non_empty_string" },
        "newName": { "$ref": "#/$defs/non_empty_string" },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "_comment": { "type": "string" },
            "affectedFiles": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/$defs/non_empty_string" },
              "description": "Every file the rename must touch (declaration, references, and imports). Closed set."
            },
            "expectedFileCount": { "type": "integer", "minimum": 1 },
            "compileCommand": {
              "type": "string",
              "description": "Optional shell command used by outcome graders to verify post-rename compile state. Default: ./gradlew --offline compileKotlin"
            }
          }
        }
      }
    },
    "large_class_slot": {
      "type": "object",
      "required": ["symbol", "fqName", "file", "description"],
      "additionalProperties": false,
      "properties": {
        "_comment": { "type": "string" },
        "symbol": { "$ref": "#/$defs/non_empty_string" },
        "fqName": { "$ref": "#/$defs/non_empty_string" },
        "file": { "$ref": "#/$defs/non_empty_string" },
        "description": { "$ref": "#/$defs/non_empty_string" },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "_comment": { "type": "string" },
            "rawFileLineCount": { "type": "integer", "minimum": 1 },
            "publicMembers": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" },
              "description": "Public members the scaffold output must mention. Anything outside this list is suspect."
            },
            "nestedTypes": {
              "type": "array",
              "items": { "$ref": "#/$defs/non_empty_string" }
            }
          }
        }
      }
    },
    "module_list_slot": {
      "type": "object",
      "required": ["modules", "description"],
      "additionalProperties": false,
      "properties": {
        "_comment": { "type": "string" },
        "modules": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "description": { "type": "string", "minLength": 1 },
        "expected": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "moduleFileCounts": {
              "type": "object",
              "description": "Map of module name to expected Kotlin source file count. Used to grade kast_workspace_files accuracy.",
              "patternProperties": {
                "^.+$": { "type": "integer", "minimum": 0 }
              },
              "additionalProperties": false
            },
            "fileCountTolerance": {
              "type": "integer",
              "minimum": 0,
              "default": 0,
              "description": "Absolute tolerance allowed when comparing reported counts to ground truth (build artifacts, generated files)."
            }
          }
        }
      }
    }
  }
}
