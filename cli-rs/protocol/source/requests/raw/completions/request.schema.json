{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "id": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonrpc": {
      "enum": [
        "2.0"
      ],
      "type": "string"
    },
    "method": {
      "enum": [
        "raw/completions"
      ],
      "type": "string"
    },
    "params": {
      "additionalProperties": false,
      "properties": {
        "kindFilter": {
          "items": {
            "type": "string"
          },
          "type": [
            "array",
            "null"
          ]
        },
        "maxResults": {
          "type": "integer"
        },
        "position": {
          "additionalProperties": false,
          "properties": {
            "filePath": {
              "type": "string"
            },
            "offset": {
              "type": "integer"
            }
          },
          "required": [
            "filePath",
            "offset"
          ],
          "type": "object"
        }
      },
      "required": [
        "position"
      ],
      "type": "object"
    }
  },
  "required": [
    "jsonrpc",
    "method",
    "params",
    "id"
  ],
  "title": "Kast raw/completions JSON-RPC request",
  "type": "object"
}
