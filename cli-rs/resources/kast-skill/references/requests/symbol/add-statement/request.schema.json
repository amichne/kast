        "contentFile": {
          "type": "string"
        },
        "insideScope": {
          "type": "string"
        },
        "workspaceRoot": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "insideScope",
        "anchor",
        "contentFile"
      ],
      "type": "object"
