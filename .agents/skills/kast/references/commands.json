    "symbol/scaffold": {
      "method": "symbol/scaffold",
      "category": "symbol",
      "summary": "Gather structural generation context for a Kotlin file",
      "dataSource": "backend",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "targetFile": {
            "type": "string"
          },
          "targetSymbol": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "mode": {
            "type": "string",
            "optional": true,
            "enum": [
              "implement",
              "replace",
              "consolidate",
              "extract"
            ]
          },
          "kind": {
            "type": "string",
            "optional": true,
            "nullable": true,
            "enum": [
              "class",
              "interface",
              "object",
              "function",
              "property"
            ]
          }
        },
        "required": [
          "targetFile"
        ]
      },
      "responseType": "KastScaffoldResponse",
      "successType": "SCAFFOLD_SUCCESS",
      "failureType": "SCAFFOLD_FAILURE"
    },
    "symbol/resolve": {
      "method": "symbol/resolve",
      "category": "symbol",
      "summary": "Resolve a symbol by name to its declaration",
      "dataSource": "backend",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "symbol": {
            "type": "string"
          },
          "fileHint": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "kind": {
            "type": "string",
            "optional": true,
            "nullable": true,
            "enum": [
              "class",
              "interface",
              "object",
              "function",
              "property"
            ]
          },
          "containingType": {
            "type": "string",
            "optional": true,
            "nullable": true
          }
        },
        "required": [
          "symbol"
        ]
      },
      "responseType": "KastResolveResponse",
      "successType": "RESOLVE_SUCCESS",
      "failureType": "RESOLVE_FAILURE",
      "notes": [
        "The 'symbol' field takes simple names only (e.g. 'key'), never fully-qualified names.",
        "Use 'containingType' for scoping and 'fileHint' for disambiguation."
      ]
    },
    "symbol/references": {
      "method": "symbol/references",
      "category": "symbol",
      "summary": "Find every usage of a Kotlin symbol",
      "dataSource": "backend",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "symbol": {
            "type": "string"
          },
          "fileHint": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "kind": {
            "type": "string",
            "optional": true,
            "nullable": true,
            "enum": [
              "class",
              "interface",
              "object",
              "function",
              "property"
            ]
          },
          "containingType": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "includeDeclaration": {
            "type": "boolean",
            "optional": true
          }
        },
        "required": [
          "symbol"
        ]
      },
      "responseType": "KastReferencesResponse",
      "successType": "REFERENCES_SUCCESS",
      "failureType": "REFERENCES_FAILURE",
      "notes": [
        "The 'symbol' field takes simple names only.",
        "Resolve ambiguous names first with 'kind', 'containingType', or 'fileHint'."
      ]
    },
    "symbol/callers": {
      "method": "symbol/callers",
      "category": "symbol",
      "summary": "Expand an incoming or outgoing call hierarchy",
      "dataSource": "backend",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "symbol": {
            "type": "string"
          },
          "fileHint": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "kind": {
            "type": "string",
            "optional": true,
            "nullable": true,
            "enum": [
              "class",
              "interface",
              "object",
              "function",
              "property"
            ]
          },
          "containingType": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "direction": {
            "type": "string",
            "optional": true,
            "enum": [
              "incoming",
              "outgoing"
            ]
          },
          "depth": {
            "type": "integer",
            "optional": true
          },
          "maxTotalCalls": {
            "type": "integer",
            "optional": true,
            "nullable": true
          },
          "maxChildrenPerNode": {
            "type": "integer",
            "optional": true,
            "nullable": true
          },
          "timeoutMillis": {
            "type": "integer",
            "optional": true,
            "nullable": true
          }
        },
        "required": [
          "symbol"
        ]
      },
      "responseType": "KastCallersResponse",
      "successType": "CALLERS_SUCCESS",
      "failureType": "CALLERS_FAILURE",
      "notes": [
        "The 'symbol' field takes simple names only."
      ]
    },
    "symbol/rename": {
      "method": "symbol/rename",
      "category": "symbol",
      "summary": "Resolve or target a symbol and apply a rename",
      "dataSource": "backend",
      "request": {
        "fields": {
          "type": {
            "type": "string"
          },
          "value": {
            "type": "object"
          }
