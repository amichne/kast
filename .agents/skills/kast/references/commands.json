      },
      "responseType": "KastRenameResponse",
      "successType": "RENAME_SUCCESS",
      "failureType": "RENAME_FAILURE",
      "variants": {
        "RENAME_BY_SYMBOL_REQUEST": {
          "fields": {
            "workspaceRoot": {
              "type": "string",
              "optional": true,
              "nullable": true
            },
            "symbol": {
              "type": "string"
            },
            "newName": {
              "type": "string"
            },
            "fileHint": {
              "type": "string",
              "optional": true,
              "nullable": true
            },
            "kind": {
              "type": "string",
              "optional": true,
              "nullable": true,
              "enum": [
                "class",
                "interface",
                "object",
                "function",
                "property"
              ]
            },
            "containingType": {
              "type": "string",
              "optional": true,
              "nullable": true
            }
          },
          "required": [
            "symbol",
            "newName"
          ]
        },
        "RENAME_BY_OFFSET_REQUEST": {
          "fields": {
            "workspaceRoot": {
              "type": "string",
              "optional": true,
              "nullable": true
            },
            "filePath": {
              "type": "string"
            },
            "offset": {
              "type": "integer"
            },
            "newName": {
              "type": "string"
            }
          },
          "required": [
            "filePath",
            "offset",
            "newName"
          ]
        }
      }
    },
