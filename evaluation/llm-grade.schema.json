{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amichne/kast/evaluation/llm-grade.schema.json",
  "title": "Kast evaluation llm-graded artifact",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "status",
    "expectations",
    "summary"
  ],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://github.com/amichne/kast/evaluation/llm-grade.schema.json"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "expectations": {
      "type": "array"
    },
    "summary": {
      "type": "object"
    },
    "rubric_results": {
      "type": "array"
    }
  }
}
