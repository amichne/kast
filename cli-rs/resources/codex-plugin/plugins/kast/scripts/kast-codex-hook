#!/bin/sh
set -eu

if [ "$#" -ne 1 ]; then
  printf '%s\n' '{"continue":true,"systemMessage":"Kast hook skipped: expected one event."}'
  exit 0
fi

: "${HOME:?HOME must be set}"
kast_home=${KAST_HOME:-$HOME/.local/share/kast}
kast_binary=$kast_home/current/bin/kast
if [ ! -x "$kast_binary" ]; then
  printf '%s\n' '{"continue":true,"systemMessage":"Kast hook skipped: the active setup release is unavailable; rerun kast setup --source <bundle>."}'
  exit 0
fi

exec "$kast_binary" developer codex hook "$1"
