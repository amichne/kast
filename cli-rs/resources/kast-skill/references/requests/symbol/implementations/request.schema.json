{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "id": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonrpc": {
      "enum": [
        "2.0"
      ],
      "type": "string"
    },
    "method": {
      "enum": [
        "symbol/implementations"
      ],
      "type": "string"
    },
    "params": {
      "additionalProperties": false,
      "properties": {
        "maxResults": {
          "type": "integer"
        },
        "pageToken": {
          "type": [
            "string",
            "null"
          ]
        },
        "selector": {
          "additionalProperties": false,
          "properties": {
            "containingType": {
              "type": [
                "string",
                "null"
              ]
            },
            "declarationFile": {
              "type": "string"
            },
            "declarationStartOffset": {
              "type": "integer"
            },
            "fqName": {
              "type": "string"
            },
            "kind": {
              "enum": [
                "CLASS",
                "INTERFACE",
                "OBJECT",
                "FUNCTION",
                "PROPERTY",
                "PARAMETER",
                "UNKNOWN",
                null
              ],
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "fqName",
            "declarationFile",
            "declarationStartOffset"
          ],
          "type": "object"
        },
        "workspaceRoot": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "selector"
      ],
      "type": "object"
    }
  },
  "required": [
    "jsonrpc",
    "method",
    "params",
    "id"
  ],
  "title": "Kast symbol/implementations JSON-RPC request",
  "type": "object"
}
