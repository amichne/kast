{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "id": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonrpc": {
      "enum": [
        "2.0"
      ],
      "type": "string"
    },
    "method": {
      "enum": [
        "database/metrics"
      ],
      "type": "string"
    },
    "params": {
      "additionalProperties": false,
      "properties": {
        "depth": {
          "type": "integer"
        },
        "fileGlob": {
          "type": [
            "string",
            "null"
          ]
        },
        "folderFilter": {
          "type": [
            "string",
            "null"
          ]
        },
        "limit": {
          "type": "integer"
        },
        "metric": {
          "enum": [
            "fanIn",
            "fanOut",
            "deadCode",
            "impact",
            "coupling",
            "search",
            "graph"
          ],
          "type": "string"
        },
        "offset": {
          "type": "integer"
        },
        "subject": {
          "additionalProperties": false,
          "properties": {
            "declarationFile": {
              "type": "string"
            },
            "declarationStartOffset": {
              "type": "integer"
            },
            "fqName": {
              "type": "string"
            },
            "kind": {
              "enum": [
                "CLASS",
                "INTERFACE",
                "OBJECT",
                "FUNCTION",
                "PROPERTY"
              ],
              "type": "string"
            }
          },
          "required": [
            "fqName",
            "declarationFile",
            "declarationStartOffset",
            "kind"
          ],
          "type": "object"
        },
        "symbol": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspaceRoot": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "metric"
      ],
      "type": "object"
    }
  },
  "required": [
    "jsonrpc",
    "method",
    "params",
    "id"
  ],
  "title": "Kast database/metrics JSON-RPC request",
  "type": "object"
}
