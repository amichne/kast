<idea-plugin>
    <id>io.github.amichne.kast.headless</id>
    <name>Kast Headless Analysis Backend</name>
    <vendor url="https://github.com/amichne/kast">amichne</vendor>
    <description>Kast headless analysis backend for IDEA Community</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>com.intellij.modules.java</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="false" supportsK2="true" />
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <appStarter id="kast-headless"
                    implementation="io.github.amichne.kast.headless.HeadlessApplicationStarter"/>
        <supportsKotlinPluginMode supportsK1="false" supportsK2="true" />
    </extensions>
</idea-plugin>
