{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amichne/kast/evaluation/grading.schema.json",
  "title": "Kast evaluation grading result",
  "description": "Merged per-run grading contract. The merged file preserves the mechanical, LLM-graded, and combined evidence surfaces while retaining compatibility aliases for summary/execution consumers.",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "status",
    "mechanical",
    "llm_graded",
    "combined",
    "expectations",
    "summary",
    "execution_metrics",
    "timing",
    "integrity"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://github.com/amichne/kast/evaluation/grading.schema.json"
    },
    "schema_version": {
      "type": "integer",
      "const": 3
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "mechanical": {
      "$ref": "#/$defs/gradingSurface"
    },
    "llm_graded": {
      "$ref": "#/$defs/gradingSurface"
    },
    "combined": {
      "$ref": "#/$defs/gradingSurface"
    },
    "expectations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/expectation"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "execution_metrics": {
      "$ref": "#/$defs/executionMetrics"
    },
    "timing": {
      "$ref": "#/$defs/timing"
    },
    "integrity": {
      "$ref": "#/$defs/integrity"
    }
  },
  "$defs": {
    "expectation": {
      "type": "object",
      "required": [
        "text",
        "passed",
        "evidence",
        "kind",
        "applicability",
        "graded_by"
      ],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string", "minLength": 1 },
        "passed": { "type": "boolean" },
        "evidence": { "type": ["string", "object"] },
        "kind": { "type": "string", "enum": ["outcome", "process"] },
        "dimension": { "type": "string" },
        "applicability": { "type": "string", "enum": ["both", "with_skill_only", "without_skill_only"] },
        "graded_by": { "type": "string", "enum": ["script", "llm", "n/a"] },
        "oracle": { "type": "string" },
        "skipped": { "type": "boolean" }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "passed",
        "failed",
        "total",
        "pass_rate",
        "outcome_passed",
        "outcome_total",
        "outcome_pass_rate",
        "process_pass_rate",
        "skipped"
      ],
      "additionalProperties": true,
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 },
        "pass_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "outcome_passed": { "type": "integer", "minimum": 0 },
        "outcome_total": { "type": "integer", "minimum": 0 },
        "outcome_pass_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "process_pass_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "skipped": { "type": "integer", "minimum": 0 }
      }
    },
    "executionMetrics": {
      "type": "object",
      "required": [
        "tool_calls",
        "total_tool_calls",
        "total_steps",
        "errors_encountered",
        "output_chars",
        "transcript_chars"
      ],
      "additionalProperties": true,
      "properties": {
        "tool_calls": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "tool_call_log": { "type": "string" },
        "total_tool_calls": { "type": "integer", "minimum": 0 },
        "total_steps": { "type": "integer", "minimum": 0 },
        "errors_encountered": { "type": "integer", "minimum": 0 },
        "output_chars": { "type": "integer", "minimum": 0 },
        "transcript_chars": { "type": "integer", "minimum": 0 },
        "kast_calls": { "type": "integer", "minimum": 0 },
        "grep_or_find_calls": { "type": "integer", "minimum": 0 }
      }
    },
    "timing": {
      "type": "object",
      "required": [
        "executor_duration_seconds",
        "grader_duration_seconds",
        "total_duration_seconds"
      ],
      "additionalProperties": true,
      "properties": {
        "executor_duration_seconds": { "type": "number", "minimum": 0.0 },
        "grader_duration_seconds": { "type": "number", "minimum": 0.0 },
        "total_duration_seconds": { "type": "number", "minimum": 0.0 },
        "executor_duration_source": { "type": "string" }
      }
    },
    "integrity": {
      "type": "object",
      "required": [
        "contradictions",
        "baseline_isolation_violation",
        "attempts",
        "flaky"
      ],
      "additionalProperties": true,
      "properties": {
        "contradictions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "baseline_isolation_violation": { "type": "boolean" },
        "attempts": { "type": "integer", "minimum": 1 },
        "flaky": { "type": "boolean" }
      }
    },
    "gradingSurface": {
      "type": "object",
      "required": [
        "status",
        "expectations",
        "summary"
      ],
      "additionalProperties": true,
      "properties": {
        "status": { "type": "string", "minLength": 1 },
        "expectations": {
          "type": "array",
          "items": { "$ref": "#/$defs/expectation" }
        },
        "summary": { "$ref": "#/$defs/summary" },
        "execution_metrics": { "$ref": "#/$defs/executionMetrics" },
        "timing": { "$ref": "#/$defs/timing" },
        "integrity": { "$ref": "#/$defs/integrity" }
      }
    }
  }
}
