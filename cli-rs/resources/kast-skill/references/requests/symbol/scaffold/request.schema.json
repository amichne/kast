{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "id": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonrpc": {
      "enum": [
        "2.0"
      ],
      "type": "string"
    },
    "method": {
      "enum": [
        "symbol/scaffold"
      ],
      "type": "string"
    },
    "params": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "enum": [
            "class",
            "interface",
            "object",
            "function",
            "property",
            null
          ],
          "type": [
            "string",
            "null"
          ]
        },
        "mode": {
          "enum": [
            "implement",
            "replace",
            "consolidate",
            "extract"
          ],
          "type": "string"
        },
        "targetFile": {
          "type": "string"
        },
        "targetSymbol": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspaceRoot": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "targetFile"
      ],
      "type": "object"
    }
  },
  "required": [
    "jsonrpc",
    "method",
    "params",
    "id"
  ],
  "title": "Kast symbol/scaffold JSON-RPC request",
  "type": "object"
}
