{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amichne/kast/evaluation/provenance.schema.json",
  "title": "Kast evaluation provenance coverage",
  "description": "Curated, sanitized provenance linking canonical evaluation cases and adjacent history-derived archetypes back to real Copilot sessions without committing raw transcripts.",
  "type": "object",
  "required": [
    "$schema",
    "version",
    "generated_at",
    "source",
    "case_coverage",
    "novel_archetypes"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "enum": ["https://github.com/amichne/kast/evaluation/provenance.schema.json"]
    },
    "version": {
      "type": "integer",
      "enum": [1]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": [
        "repository",
        "method",
        "note"
      ],
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "case_coverage": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case_coverage"
      }
    },
    "novel_archetypes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/novel_archetype"
      }
    }
  },
  "$defs": {
    "history_entry": {
      "type": "object",
      "required": [
        "session_id",
        "created_at",
        "summary",
        "excerpt",
        "rationale"
      ],
      "additionalProperties": false,
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "excerpt": {
          "type": "string",
          "minLength": 1
        },
        "rationale": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "case_coverage": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "eval_id",
            "status",
            "entries"
          ],
          "additionalProperties": false,
          "properties": {
            "eval_id": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "enum": ["matched"]
            },
            "entries": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/history_entry"
              }
            }
          }
        },
        {
          "type": "object",
          "required": [
            "eval_id",
            "status",
            "gap_reason"
          ],
          "additionalProperties": false,
          "properties": {
            "eval_id": {
              "type": "string",
              "minLength": 1
            },
            "status": {
              "type": "string",
              "enum": ["gap"]
            },
            "gap_reason": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "novel_archetype": {
      "type": "object",
      "required": [
        "id",
        "title",
        "summary",
        "source_entries"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source_entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/history_entry"
          }
        }
      }
    }
  }
}
