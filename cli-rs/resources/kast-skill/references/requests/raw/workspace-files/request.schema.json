{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "id": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonrpc": {
      "enum": [
        "2.0"
      ],
      "type": "string"
    },
    "method": {
      "enum": [
        "raw/workspace-files"
      ],
      "type": "string"
    },
    "params": {
      "additionalProperties": false,
      "properties": {
        "includeFiles": {
          "type": "boolean"
        },
        "kindDomain": {
          "enum": [
            "SOURCE_ONLY",
            "SCRIPT_ONLY",
            "MIXED"
          ],
          "type": "string"
        },
        "maxFilesPerModule": {
          "type": [
            "integer",
            "null"
          ]
        },
        "moduleName": {
          "type": [
            "string",
            "null"
          ]
        },
        "pageToken": {
          "type": [
            "string",
            "null"
          ]
        },
        "snapshotToken": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "type": "object"
    }
  },
  "required": [
    "jsonrpc",
    "method",
    "params",
    "id"
  ],
  "title": "Kast raw/workspace-files JSON-RPC request",
  "type": "object"
}
