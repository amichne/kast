{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amichne/kast/evaluation/mock-backend.schema.json",
  "title": "Kast evaluation mock backend payloads",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "generated_at",
    "target_repo",
    "workspace_root",
    "entries",
    "provenance_summary"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://github.com/amichne/kast/evaluation/mock-backend.schema.json"
    },
    "schema_version": { "type": "integer", "const": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "target_repo": { "type": "string" },
    "workspace_root": { "type": "string" },
    "catalog_version": { "type": "integer", "minimum": 1 },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    },
    "provenance_summary": {
      "type": "object",
      "required": [
        "history_roots",
        "history_entry_count",
        "fallback_entry_count",
        "rejected_history_entry_count"
      ],
      "additionalProperties": false,
      "properties": {
        "history_roots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "history_entry_count": { "type": "integer", "minimum": 0 },
        "fallback_entry_count": { "type": "integer", "minimum": 0 },
        "rejected_history_entry_count": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["method", "matcher", "result", "provenance"],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "raw/workspace-files",
            "raw/workspace-symbol",
            "raw/workspace-search",
            "raw/file-outline",
            "symbol/scaffold",
            "symbol/resolve",
            "symbol/references",
            "symbol/callers",
            "symbol/rename",
            "symbol/write-and-validate",
            "database/metrics",
            "raw/diagnostics"
          ]
        },
        "matcher": {
          "type": "object",
          "additionalProperties": true
        },
        "result": {
          "type": "object",
          "additionalProperties": true
        },
        "provenance": {
          "type": "object",
          "required": ["source", "fallback"],
          "additionalProperties": true,
          "properties": {
            "source": { "type": "string", "enum": ["history", "bindings"] },
            "fallback": { "type": "boolean" },
            "source_file": { "type": "string" },
            "tool_call_id": { "type": "string" }
          }
        }
      }
    }
  }
}
