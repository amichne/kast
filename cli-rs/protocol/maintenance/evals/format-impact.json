{
  "$schema": "./format-impact.schema.json",
  "schemaVersion": 1,
  "description": "Report-only paired JSON versus TOON cases for measuring Kast typed-agent output comprehension, route accuracy, and byte cost without making live model results a CI gate.",
  "formats": [
    "json",
    "toon"
  ],
  "cases": [
    {
      "id": "typed-command-plan-comprehension",
      "scenario": "TYPED_COMMAND_PLAN_COMPREHENSION",
      "prompt": "Given a read-only Kast rename plan, identify the selected typed command, explain why mutation has not happened yet, and name the follow-up command to apply it.",
      "pairedFormats": [
        "json",
        "toon"
      ],
      "inputArtifact": {
        "kind": "agent-rename-plan",
        "description": "Use `kast agent rename` without `--apply` in JSON and TOON forms."
      },
      "expectedPrimitive": {
        "type": "skill",
        "name": "kast"
      },
      "expectedActions": [
        {
          "kind": "command",
          "name": "kast agent rename --symbol --new-name --apply"
        }
      ],
      "forbiddenActions": [
        "grep",
        "rg",
        "manual edit before apply",
        "raw JSON-RPC dispatch"
      ],
      "goldFacts": [
        "The envelope method is agent/rename.",
        "The result type is KAST_AGENT_RENAME_PLAN.",
        "The plan is read-only until the same typed command is rerun with --apply."
      ],
      "answerScoring": {
        "requiredTerms": [
          "agent/rename",
          "KAST_AGENT_RENAME_PLAN",
          "--apply"
        ],
        "forbiddenTerms": [
          "grep",
          "rg",
          "manual edit before apply",
          "raw JSON-RPC dispatch"
        ]
      },
      "metrics": [
        "routeAccuracy",
        "fieldAccuracy",
        "forbiddenFallbacks",
        "stdoutBytes",
        "decodedEquivalent"
      ],
      "reportOnly": true
    },
    {
      "id": "symbol-result-extraction",
      "scenario": "SYMBOL_RESULT_EXTRACTION",
      "prompt": "Given a typed symbol lookup envelope, extract the command method, resolved declaration identity, file path, and next inspection action without inventing fields.",
      "pairedFormats": [
        "json",
        "toon"
      ],
      "inputArtifact": {
        "kind": "synthetic-envelope",
        "description": "Use a stable typed `kast agent symbol` result encoded as JSON and TOON."
      },
      "expectedPrimitive": {
        "type": "skill",
        "name": "kast"
      },
      "expectedActions": [
        {
          "kind": "command",
          "name": "kast agent diagnostics --file-path"
        }
      ],
      "forbiddenActions": [
        "grep",
        "rg",
        "invented response fields",
        "generic file read before Kast"
      ],
      "goldFacts": [
        "The envelope method is agent/symbol.",
        "The declaration is EventBean.",
        "The file path must be read from result data, not inferred from the package name."
      ],
      "answerScoring": {
        "requiredTerms": [
          "agent/symbol",
          "EventBean",
          "src/main/kotlin/com/example/EventBean.kt",
          "diagnostics"
        ],
        "forbiddenTerms": [
          "grep",
          "rg",
          "invented response fields",
          "generic file read before Kast"
        ]
      },
      "metrics": [
        "fieldAccuracy",
        "answerVerdict",
        "forbiddenFallbacks",
        "decodedEquivalent"
      ],
      "reportOnly": true
    },
    {
      "id": "relationship-navigation-continuation",
      "scenario": "RELATIONSHIP_NAVIGATION",
      "prompt": "Continue from a resolved Kotlin declaration by finding usages and incoming callers, preserving symbol identity across typed Kast commands.",
      "pairedFormats": [
        "json",
        "toon"
      ],
      "inputArtifact": {
        "kind": "synthetic-envelope",
        "description": "Use a typed symbol envelope that contains enough identity to request references and callers."
      },
      "expectedPrimitive": {
        "type": "skill",
        "name": "kast"
      },
      "expectedActions": [
        {
          "kind": "command",
          "name": "kast agent references --symbol --declaration-file --declaration-start-offset"
        },
        {
          "kind": "command",
          "name": "kast agent callers --symbol --declaration-file --declaration-start-offset"
        }
      ],
      "forbiddenActions": [
        "grep",
        "rg",
        "textual call graph",
        "unresolved name matching"
      ],
      "goldFacts": [
        "The continuation must use standalone typed references or callers commands with the complete resolved selector.",
        "The action must preserve the resolved symbol identity.",
        "Text matching is not an acceptable replacement."
      ],
      "answerScoring": {
        "requiredTerms": [
          "EventBean",
          "agent references",
          "agent callers",
          "--declaration-file",
          "--declaration-start-offset"
        ],
        "forbiddenTerms": [
          "grep",
          "rg",
          "textual call graph",
          "unresolved name matching"
        ]
      },
      "metrics": [
        "routeAccuracy",
        "fieldAccuracy",
        "forbiddenFallbacks",
        "decodedEquivalent"
      ],
      "reportOnly": true
    },
    {
      "id": "read-only-plan-recovery",
      "scenario": "READ_ONLY_PLAN_RECOVERY",
      "prompt": "Given a rename plan that says applyRequired=true, preserve the same symbol and new name, then choose the typed command that performs the mutation.",
      "pairedFormats": [
        "json",
        "toon"
      ],
      "inputArtifact": {
        "kind": "agent-rename-plan",
        "description": "Use a read-only rename plan from the supported typed command."
      },
      "expectedPrimitive": {
        "type": "skill",
        "name": "kast"
      },
      "expectedActions": [
        {
          "kind": "command",
          "name": "kast agent rename --symbol --new-name --apply"
        }
      ],
      "forbiddenActions": [
        "grep",
        "rg",
        "changing symbol identity",
        "manual package inference"
      ],
      "goldFacts": [
        "The plan has applyRequired=true.",
        "Mutation requires the typed rename command with --apply.",
        "The symbol and new name must be preserved from the plan."
      ],
      "answerScoring": {
        "requiredTerms": [
          "applyRequired",
          "--apply",
          "EventRecord"
        ],
        "forbiddenTerms": [
          "grep",
          "rg",
          "changing symbol identity",
          "manual package inference"
        ]
      },
      "metrics": [
        "routeAccuracy",
        "fieldAccuracy",
        "answerVerdict",
        "decodedEquivalent"
      ],
      "reportOnly": true
    },
    {
      "id": "typed-sequence-evidence",
      "scenario": "TYPED_SEQUENCE_EVIDENCE",
      "prompt": "Given typed symbol output, describe a repeatable evidence sequence for a rename and diagnostics pass using only supported Kast commands.",
      "pairedFormats": [
        "json",
        "toon"
      ],
      "inputArtifact": {
        "kind": "synthetic-envelope",
        "description": "Use typed symbol output that names follow-up diagnostics and symbol-preserving actions."
      },
      "expectedPrimitive": {
        "type": "skill",
        "name": "kast"
      },
      "expectedActions": [
        {
          "kind": "command",
          "name": "kast agent verify"
        },
        {
          "kind": "command",
          "name": "kast agent rename --symbol --new-name"
        },
        {
          "kind": "command",
          "name": "kast agent diagnostics --file-path"
        }
      ],
      "forbiddenActions": [
        "grep",
        "rg",
        "ad hoc protocol transport",
        "treating dry-run as mutation proof"
      ],
      "goldFacts": [
        "The repeatable sequence uses typed commands.",
        "Rename planning is separate from applying mutation.",
        "Diagnostics remain the validation step after changes."
      ],
      "answerScoring": {
        "requiredTerms": [
          "verify",
          "rename",
          "diagnostics",
          "typed"
        ],
        "forbiddenTerms": [
          "grep",
          "rg",
          "ad hoc protocol transport",
          "treating dry-run as mutation proof"
        ]
      },
      "metrics": [
        "fieldAccuracy",
        "answerVerdict",
        "stdoutBytes",
        "decodedEquivalent"
      ],
      "reportOnly": true
    },
    {
      "id": "non-kotlin-negative-routing",
      "scenario": "NEGATIVE_ROUTING",
      "prompt": "Update docs/commands/install.md copy and run the docs content contract. No Kotlin or Kast package-state question is involved.",
      "pairedFormats": [
        "json",
        "toon"
      ],
      "inputArtifact": {
        "kind": "prompt-only",
        "description": "No Kast output should be needed for this unrelated docs task."
      },
      "expectedPrimitive": {
        "type": "none",
        "name": "none"
      },
      "expectedActions": [
        {
          "kind": "generic",
          "name": "normal file read"
        }
      ],
      "forbiddenActions": [
        "kast agent symbol",
        "kast agent impact",
        "semantic backend warmup"
      ],
      "goldFacts": [
        "The task is docs-only.",
        "No Kotlin semantic route should be selected."
      ],
      "answerScoring": {
        "requiredTerms": [
          "docs/commands/install.md",
          "docs content contract"
        ],
        "forbiddenTerms": [
          "kast agent symbol",
          "kast agent impact",
          "semantic backend warmup"
        ]
      },
      "metrics": [
        "routeAccuracy",
        "forbiddenFallbacks",
        "answerVerdict"
      ],
      "reportOnly": true
    },
    {
      "id": "large-typed-output-efficiency",
      "scenario": "LARGE_READ_ONLY_OUTPUT",
      "prompt": "Compare JSON and TOON forms of a typed Kast symbol result and report whether the denser form preserves semantics while reducing stdout bytes.",
      "pairedFormats": [
        "json",
        "toon"
      ],
      "inputArtifact": {
        "kind": "synthetic-envelope",
        "description": "Use a typed read-only agent result with nested step data."
      },
      "expectedPrimitive": {
        "type": "skill",
        "name": "kast"
      },
      "expectedActions": [
        {
          "kind": "command",
          "name": "kast agent symbol --query"
        }
      ],
      "forbiddenActions": [
        "grep",
        "rg",
        "tokenizer dependency",
        "schema change"
      ],
      "goldFacts": [
        "TOON decodes to the same JSON value as explicit JSON output.",
        "TOON stdout bytes are lower than pretty JSON bytes.",
        "The typed result preserves method, step, and symbol fields."
      ],
      "answerScoring": {
        "requiredTerms": [
          "TOON",
          "same JSON value",
          "lower",
          "agent/symbol",
          "EventBean"
        ],
        "forbiddenTerms": [
          "grep",
          "rg",
          "tokenizer dependency",
          "schema change"
        ]
      },
      "metrics": [
        "stdoutBytes",
        "decodedEquivalent",
        "fieldAccuracy",
        "answerVerdict"
      ],
      "reportOnly": true
    }
  ]
}
