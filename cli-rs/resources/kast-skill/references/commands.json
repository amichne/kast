    "symbol/scaffold": {
      "method": "symbol/scaffold",
      "category": "symbol",
      "summary": "Gather structural generation context for a Kotlin file",
      "dataSource": "backend",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "targetFile": {
            "type": "string"
          },
          "targetSymbol": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "mode": {
            "type": "string",
            "optional": true,
            "enum": [
              "implement",
              "replace",
              "consolidate",
              "extract"
            ]
          },
          "kind": {
            "type": "string",
            "optional": true,
            "nullable": true,
            "enum": [
              "class",
              "interface",
              "object",
              "function",
              "property"
            ]
          }
        },
        "required": [
          "targetFile"
        ]
      },
      "responseType": "KastScaffoldResponse",
      "successType": "SCAFFOLD_SUCCESS",
      "failureType": "SCAFFOLD_FAILURE",
      "tool": {
        "name": "kast_scaffold",
        "description": "Summarize a Kotlin file or type structure: declarations, signatures, imports, key call sites, and full file content. Prefer this over generic file reads for .kt and .kts files."
      }
    },
    "symbol/discover": {
      "method": "symbol/discover",
      "category": "symbol",
      "summary": "Rank candidate declarations for a simple symbol name",
      "dataSource": "backend",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "symbol": {
            "type": "string"
          },
          "fileHint": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "line": {
            "type": "integer",
            "optional": true,
            "nullable": true
          },
          "codeSnippet": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "kind": {
            "type": "string",
            "optional": true,
            "nullable": true,
            "enum": [
              "class",
              "interface",
              "object",
              "function",
              "property"
            ]
          },
          "containingType": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "maxResults": {
            "type": "integer",
            "optional": true
          },
          "includeDeclarationScope": {
            "type": "boolean",
            "optional": true
          }
        },
        "required": [
          "symbol"
        ]
      },
      "responseType": "KastDiscoverResponse",
      "successType": "DISCOVER_SUCCESS",
      "failureType": "DISCOVER_FAILURE",
      "notes": [
        "Use this before symbol/resolve when a simple name is ambiguous or context is available.",
        "Candidates include resolveParams and nextRequest fields that can be sent to symbol/resolve."
      ],
      "tool": {
        "name": "kast_symbol_discover",
        "description": "Rank candidate Kotlin declarations for a simple symbol name, optionally using file, line, and snippet context. Use before kast_resolve when a name is ambiguous; each candidate returns resolveParams and a nextRequest."
      }
    },
    "symbol/query": {
      "method": "symbol/query",
      "category": "symbol",
      "summary": "Query compiler-indexed declarations with symbolic hard filters, fielded lexical/name matching, bounded graph relationship evidence, and optional semantic discovery evidence",
      "dataSource": "sqlite",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "query": {
            "type": "string"
          },
          "modes": {
            "type": "array",
            "optional": true,
            "items": {
              "type": "string",
              "enum": [
                "exact",
                "lexical",
                "structural",
                "graph",
                "semantic"
              ]
            }
          },
          "filters": {
            "type": "object",
            "optional": true,
            "fields": {
              "kinds": {
                "type": "array",
                "optional": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "CLASS",
                    "INTERFACE",
                    "OBJECT",
                    "FUNCTION",
                    "PROPERTY",
                    "TYPEALIAS",
                    "ENUM_CLASS",
                    "ENUM_ENTRY",
                    "CONSTRUCTOR"
                  ]
                }
              },
              "visibility": {
                "type": "array",
                "optional": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "PUBLIC",
                    "INTERNAL",
                    "PROTECTED",
                    "PRIVATE",
                    "LOCAL"
                  ]
                }
              },
              "modulePath": {
                "type": "string",
                "optional": true,
                "nullable": true
              },
              "sourceSet": {
                "type": "string",
                "optional": true,
                "nullable": true
              },
              "fileGlob": {
                "type": "string",
                "optional": true,
                "nullable": true
              },
              "packagePrefix": {
                "type": "string",
                "optional": true,
                "nullable": true
              },
              "fqNamePrefix": {
                "type": "string",
                "optional": true,
                "nullable": true
              },
              "gradleProject": {
                "type": "string",
                "description": "Gradle project path filter. Matches an exact project such as :lib or child projects such as :lib:payments; an optional source-set suffix like [main] is ignored.",
                "optional": true,
                "nullable": true
              },
              "relativePathPrefix": {
                "type": "string",
                "description": "Matches the workspace-root-relative path prefix from path_prefixes plus filename, using normalized slash-separated segments.",
                "optional": true,
                "nullable": true
              },
              "productionOnly": {
                "type": "boolean",
                "description": "Restricts results to sourceSet=main and excludes build logic locations such as buildSrc and build-logic.",
                "optional": true
              },
              "excludePatterns": {
                "type": "array",
                "description": "Glob patterns matched against module path or relative path; matching declarations are excluded.",
                "optional": true,
                "items": "string"
              },
              "usageFacets": {
                "type": "array",
                "description": "Filters by computed declaration facets derived from declarations, references, metadata, and supertypes.",
                "optional": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "PUBLIC_API",
                    "INTERNAL_API",
                    "MODULE_PRIVATE",
                    "BRIDGE",
                    "BUILD_LOGIC"
                  ]
                }
              }
            }
          },
          "anchor": {
            "type": "object",
            "optional": true,
            "fields": {
              "fqName": {
                "type": "string",
                "optional": true,
                "nullable": true
              },
              "symbol": {
                "type": "string",
                "optional": true,
                "nullable": true
              },
              "filePath": {
                "type": "string",
                "optional": true,
                "nullable": true
              },
              "offset": {
                "type": "integer",
                "optional": true,
                "nullable": true
              }
            }
          },
          "graph": {
            "type": "object",
            "optional": true,
            "fields": {
              "direction": {
                "type": "string",
                "optional": true,
                "enum": [
                  "INCOMING",
                  "OUTGOING",
                  "BOTH"
                ]
              },
              "edgeKinds": {
                "type": "array",
                "optional": true,
                "items": {
                  "type": "string",
                  "enum": [
                    "CALL",
                    "TYPE_REF",
                    "INHERITANCE",
                    "OVERRIDE",
                    "IMPORT",
                    "ANNOTATION",
                    "UNKNOWN"
                  ]
                }
              },
              "depth": {
                "type": "integer",
                "optional": true
              },
              "maxEdgesPerResult": {
                "type": "integer",
                "optional": true
              }
            }
          },
          "semantic": {
            "type": "object",
            "optional": true,
            "fields": {
              "enabled": {
                "type": "boolean",
                "optional": true
              },
              "profile": {
                "type": "string",
                "optional": true,
                "enum": [
                  "identity",
                  "behavior",
                  "api_usage"
                ]
              },
              "maxCandidates": {
                "type": "integer",
                "optional": true
              }
            }
          },
          "limit": {
            "type": "integer",
            "optional": true
          },
          "includeEvidence": {
            "type": "boolean",
            "optional": true
          },
          "includeNextRequests": {
            "type": "boolean",
            "optional": true
          }
        },
        "required": [
          "query"
        ]
      },
      "responseType": "KastSymbolQueryResponse",
      "successType": "SYMBOL_QUERY_SUCCESS",
      "failureType": "SYMBOL_QUERY_FAILURE",
      "failureReasons": [
        "INDEX_UNAVAILABLE",
        "INVALID_FILTER",
        "QUERY_TOO_BROAD",
        "AMBIGUOUS_ANCHOR",
        "ANCHOR_NOT_FOUND",
        "SEMANTIC_UNAVAILABLE",
        "TIMEOUT"
      ],
      "notes": [
        "Handled by the Rust CLI before daemon passthrough; JVM backends do not read this SQLite surface.",
        "Hard filters are enforced by SQLite/compiler facts, never by semantic score.",
        "Nested filters include gradleProject, relativePathPrefix, productionOnly, excludePatterns, and usageFacets.",
        "usageFacets is the supported public filter for computed declaration facets; symbol/query does not expose clusterKinds.",
        "Token matching is computed by the Rust CLI from query text and indexed declaration fields without persisted token tables.",
        "Graph depth defaults to 1 and is capped at 2 in the first implementation.",
        "Semantic discovery is represented in the response shape but reports available=false until a sidecar exists."
      ]
    },
    "symbol/resolve": {
      "method": "symbol/resolve",
      "category": "symbol",
      "summary": "Resolve a symbol by name to its declaration and optional context",
      "dataSource": "backend",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "symbol": {
            "type": "string"
          },
          "fileHint": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "kind": {
            "type": "string",
            "optional": true,
            "nullable": true,
            "enum": [
              "class",
              "interface",
              "object",
              "function",
              "property"
            ]
          },
          "containingType": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "includeDeclarationScope": {
            "type": "boolean",
            "optional": true
          },
          "includeDocumentation": {
            "type": "boolean",
            "optional": true
          },
          "surroundingLines": {
            "type": "integer",
            "optional": true,
            "nullable": true
          },
          "includeSurroundingMembers": {
            "type": "boolean",
            "optional": true
          }
        },
        "required": [
          "symbol"
        ]
      },
      "responseType": "KastResolveResponse",
      "successType": "RESOLVE_SUCCESS",
      "failureType": "RESOLVE_FAILURE",
      "notes": [
        "The 'symbol' field takes simple names only (e.g. 'key'), never fully-qualified names.",
        "Use 'containingType' for scoping and 'fileHint' for disambiguation.",
        "Set includeDeclarationScope, includeDocumentation, surroundingLines, or includeSurroundingMembers only when the extra context is needed."
      ],
      "tool": {
        "name": "kast_resolve",
        "description": "Resolve a Kotlin symbol to its declaration. Use when a name might be overloaded, inherited, or shadowed; disambiguate with kind, containingType, and fileHint before tracing references or callers."
      }
    },
    "symbol/references": {
      "method": "symbol/references",
      "category": "symbol",
      "summary": "Find every usage of a Kotlin symbol",
      "dataSource": "backend",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "symbol": {
            "type": "string"
          },
          "fileHint": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "kind": {
            "type": "string",
            "optional": true,
            "nullable": true,
            "enum": [
              "class",
              "interface",
              "object",
              "function",
              "property"
            ]
          },
          "containingType": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "includeDeclaration": {
            "type": "boolean",
            "optional": true
          }
        },
        "required": [
          "symbol"
        ]
      },
      "responseType": "KastReferencesResponse",
      "successType": "REFERENCES_SUCCESS",
      "failureType": "REFERENCES_FAILURE",
      "notes": [
        "The 'symbol' field takes simple names only.",
        "Resolve ambiguous names first with 'kind', 'containingType', or 'fileHint'."
      ],
      "tool": {
        "name": "kast_references",
        "description": "Find every usage of a Kotlin symbol. Prefer this over grep for Kotlin identity because it can disambiguate overloads, inherited members, imports, and aliases."
      }
    },
    "symbol/callers": {
      "method": "symbol/callers",
      "category": "symbol",
      "summary": "Expand an incoming or outgoing call hierarchy",
      "dataSource": "backend",
      "request": {
        "fields": {
          "workspaceRoot": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "symbol": {
            "type": "string"
          },
          "fileHint": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "kind": {
            "type": "string",
            "optional": true,
            "nullable": true,
            "enum": [
              "class",
              "interface",
              "object",
              "function",
              "property"
            ]
          },
          "containingType": {
            "type": "string",
            "optional": true,
            "nullable": true
          },
          "direction": {
            "type": "string",
            "optional": true,
            "enum": [
              "incoming",
              "outgoing"
            ]
          },
          "depth": {
            "type": "integer",
            "optional": true
          },
          "maxTotalCalls": {
            "type": "integer",
            "optional": true,
            "nullable": true
          },
          "maxChildrenPerNode": {
            "type": "integer",
            "optional": true,
            "nullable": true
          },
          "timeoutMillis": {
            "type": "integer",
            "optional": true,
            "nullable": true
          }
        },
        "required": [
          "symbol"
        ]
      },
      "responseType": "KastCallersResponse",
      "successType": "CALLERS_SUCCESS",
      "failureType": "CALLERS_FAILURE",
      "notes": [
        "The 'symbol' field takes simple names only."
      ],
      "tool": {
        "name": "kast_callers",
        "description": "Trace incoming or outgoing call hierarchy for a Kotlin function. Use to understand flow, blast radius, or the entry points reaching a target."
      }
    },
    "symbol/rename": {
      "method": "symbol/rename",
      "category": "symbol",
      "summary": "Resolve or target a symbol and apply a rename",
      "dataSource": "backend",
      "request": {
        "fields": {
          "type": {
            "type": "string",
            "enum": [
              "RENAME_BY_SYMBOL_REQUEST",
              "RENAME_BY_OFFSET_REQUEST"
            ]
          }
        },
        "required": [
          "type"
        ]
      },
      "responseType": "KastRenameResponse",
      "successType": "RENAME_SUCCESS",
      "failureType": "RENAME_FAILURE",
      "variants": {
        "RENAME_BY_SYMBOL_REQUEST": {
          "fields": {
            "workspaceRoot": {
              "type": "string",
              "optional": true,
              "nullable": true
            },
            "symbol": {
              "type": "string"
            },
            "newName": {
              "type": "string"
            },
            "fileHint": {
              "type": "string",
              "optional": true,
              "nullable": true
            },
            "kind": {
              "type": "string",
              "optional": true,
              "nullable": true,
              "enum": [
                "class",
                "interface",
                "object",
                "function",
                "property"
              ]
            },
            "containingType": {
              "type": "string",
              "optional": true,
              "nullable": true
            }
          },
          "required": [
            "symbol",
            "newName"
          ]
        },
        "RENAME_BY_OFFSET_REQUEST": {
          "fields": {
            "workspaceRoot": {
              "type": "string",
              "optional": true,
              "nullable": true
            },
            "filePath": {
              "type": "string"
            },
            "offset": {
              "type": "integer"
            },
            "newName": {
              "type": "string"
            }
          },
          "required": [
            "filePath",
            "offset",
            "newName"
          ]
        }
      },
      "tool": {
        "name": "kast_rename",
        "description": "Rename a Kotlin symbol safely by symbol identity or file offset. Pass the type discriminator plus the fields for that variant; non-clean responses mean the rename did not commit."
      }
    },
