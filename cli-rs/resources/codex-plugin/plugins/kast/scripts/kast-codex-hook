#!/bin/sh
set -eu

if [ "$#" -ne 1 ] || [ -z "$1" ]; then
  echo "usage: kast-codex-hook <event>" >&2
  exit 2
fi

if [ -n "${KAST_AGENT_TASK_LAUNCHER:-}" ]; then
  case "$KAST_AGENT_TASK_LAUNCHER" in
    /*) ;;
    *)
      echo "KAST_AGENT_TASK_LAUNCHER must be an absolute path" >&2
      exit 1
      ;;
  esac
  task_launcher=$KAST_AGENT_TASK_LAUNCHER
else
  : "${HOME:?HOME must be set when KAST_AGENT_TASK_LAUNCHER is unset}"
  task_launcher=$HOME/.local/bin/kast-agent-task
fi

if [ ! -x "$task_launcher" ]; then
  echo "kast-agent-task launcher is not executable: $task_launcher" >&2
  exit 1
fi

launcher_dir=$(CDPATH= cd -P "$(dirname "$task_launcher")" && pwd)
kast_binary=$launcher_dir/kast
if [ ! -x "$kast_binary" ]; then
  echo "attested sibling kast is not executable: $kast_binary" >&2
  exit 1
fi

exec "$kast_binary" developer codex hook "$1"
