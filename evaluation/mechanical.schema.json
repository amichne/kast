{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/amichne/kast/evaluation/mechanical.schema.json",
  "title": "Kast evaluation mechanical grading artifact",
  "type": "object",
  "required": [
    "$schema",
    "schema_version",
    "status",
    "expectations",
    "summary",
    "execution_metrics",
    "timing",
    "integrity"
  ],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "https://github.com/amichne/kast/evaluation/mechanical.schema.json"
    },
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "expectations": {
      "type": "array"
    },
    "summary": {
      "type": "object"
    },
    "execution_metrics": {
      "type": "object"
    },
    "timing": {
      "type": "object"
    },
    "integrity": {
      "type": "object"
    }
  }
}
