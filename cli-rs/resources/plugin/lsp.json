{
  "lspServers": {
    "kotlin": {
      "command": "kast",
      "args": [
        "agent",
        "lsp",
        "--stdio"
      ],
      "fileExtensions": {
        ".kt": "kotlin",
        ".kts": "kotlin"
      },
      "rootUri": ".",
      "initializationTimeoutMs": 120000,
      "requestTimeoutMs": 90000,
      "initializationOptions": {
        "indexMode": "compiler-backed",
        "failOnStaleIndex": true,
        "preferCompilerFactsOverTextSearch": true
      }
    }
  }
}
