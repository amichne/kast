{
  "skill_name": "kast",
  "suite": "routing",
  "evals": [
    {
      "id": "understand-kotlin-file",
      "prompt": "Help me understand this Kotlin file and how it is wired into the rest of the project.",
      "expected_skill": "kast",
      "expected_route": "native-kast-tools",
      "allowed_ops": [
        "kast_workspace_files",
        "kast_scaffold",
        "kast_resolve",
        "kast_references",
        "kast_callers"
      ],
      "forbidden_ops": [
        "grep",
        "rg",
        "view"
      ],
      "failure_mode": "trigger_miss",
      "measurement_dimensions": [
        "discoverability",
        "haystack_reduction",
        "generic_tool_avoidance"
      ]
    },
    {
      "id": "trace-kotlin-flow",
      "prompt": "Trace this Kotlin flow from the controller down to the implementation and show me what calls what.",
      "expected_skill": "kast",
      "expected_route": "native-kast-tools",
      "allowed_ops": [
        "kast_scaffold",
        "kast_resolve",
        "kast_callers",
        "kast_references"
