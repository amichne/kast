{
  "id": 1,
  "jsonrpc": "2.0",
  "method": "database/metrics",
  "params": {
    "depth": 2,
    "fileGlob": "**/*.kt",
    "folderFilter": "src/main/kotlin",
    "limit": 25,
    "metric": "graph",
    "offset": 128,
    "subject": {
      "declarationFile": "example-declarationFile",
      "declarationStartOffset": 128,
      "fqName": "com.example.Widget",
      "kind": "PROPERTY"
    },
    "symbol": "Widget",
    "workspaceRoot": "/absolute/path/to/workspace"
  }
}
