{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "id": {
      "oneOf": [
        {
          "type": "integer"
        },
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ]
    },
    "jsonrpc": {
      "enum": [
        "2.0"
      ],
      "type": "string"
    },
    "method": {
      "enum": [
        "symbol/resolve"
      ],
      "type": "string"
    },
    "params": {
      "additionalProperties": false,
      "properties": {
        "containingType": {
          "type": [
            "string",
            "null"
          ]
        },
        "fileHint": {
          "type": [
            "string",
            "null"
          ]
        },
        "includeDeclarationScope": {
          "type": "boolean"
        },
        "includeDocumentation": {
          "type": "boolean"
        },
        "includeSurroundingMembers": {
          "type": "boolean"
        },
        "kind": {
          "enum": [
            "class",
            "interface",
            "object",
            "function",
            "property",
            null
          ],
          "type": [
            "string",
            "null"
          ]
        },
        "surroundingLines": {
          "type": [
            "integer",
            "null"
          ]
        },
        "symbol": {
          "type": "string"
        },
        "workspaceRoot": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "symbol"
      ],
      "type": "object"
    }
  },
  "required": [
    "jsonrpc",
    "method",
    "params",
    "id"
  ],
  "title": "Kast symbol/resolve JSON-RPC request",
  "type": "object"
}
