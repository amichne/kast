<idea-plugin>
    <id>io.github.amichne.kast</id>
    <name>Kast Analysis Backend</name>
    <vendor url="https://github.com/amichne/kast">amichne</vendor>
    <description>Kast Kotlin analysis backend for IDEA-based IDEs (IDEA, Android Studio)</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>com.intellij.gradle</depends>
    <depends>org.jetbrains.plugins.gradle</depends>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="false" supportsK2="true" />
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="io.github.amichne.kast.idea.diagnostics.KastDiagnosticsService"/>
        <projectService serviceImplementation="io.github.amichne.kast.idea.KastPluginService"/>
        <projectService serviceImplementation="io.github.amichne.kast.idea.KastSettingsState"/>
        <postStartupActivity implementation="io.github.amichne.kast.idea.KastStartupActivity"/>
        <statusBarWidgetFactory implementation="io.github.amichne.kast.idea.KastStatusBarWidgetFactory"
                                id="io.github.amichne.kast.status"/>
        <toolWindow id="Kast"
                    anchor="bottom"
                    icon="/icons/kast.svg"
                    factoryClass="io.github.amichne.kast.idea.KastToolWindowFactory"/>
        <projectConfigurable
                instance="io.github.amichne.kast.idea.KastSettingsConfigurable"
                id="io.github.amichne.kast.settings"
                displayName="Kast"
                parentId="tools"/>
        <notificationGroup id="Kast Activity" displayType="TOOL_WINDOW" toolWindowId="Kast"/>
        <notificationGroup id="Kast" displayType="BALLOON"/>
    </extensions>
</idea-plugin>
